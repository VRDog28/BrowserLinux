function evaluate(expr) {

    if (!/^[0-9+\-*/().\s]+$/.test(expr)) {
        return "Error: invalid characters";
    }

    try {
        return Function(`"use strict"; return (${expr})`)();
    } catch (e) {
        return "Error: invalid expression";
    }
}

const result = evaluate(input);

write(result + "\n", "white");

return 0;
