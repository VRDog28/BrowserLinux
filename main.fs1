let input = "";

if (window.shell.pipe && window.shell.pipe.trim() !== "") {
    input = window.shell.pipe.trim();
} else {
    write("bc: File " + shell.args[0] + " is unavailable.");
    return 1;
}

if (!input) {
    write("Interactive mode not available\n");
    return 1;
