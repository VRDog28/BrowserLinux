    count = parseInt(values["n"], 10);

    if (isNaN(count) || count < 0) {
        write("shuf: invalid count\n");
        return;
    }
}

for (let i = 0; i < Math.min(count, numbers.length); i++) {
    write(numbers[i] + "\n");
}
