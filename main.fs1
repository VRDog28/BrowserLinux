function splitArgs(input) {
    const result = [];
    let current = "";
    let inQuotes = false;
    let quoteChar = null;

    for (let i = 0; i < input.length; i++) {
        const char = input[i];
        if ((char === '"' || char === "'")) {
            if (!inQuotes) {
                inQuotes = true;
                quoteChar = char;
                continue;
            } else if (char === quoteChar) {
                inQuotes = false;
                quoteChar = null;
                continue;
            }
        }
        if (char === " " && !inQuotes) {
            if (current.length > 0) {
                result.push(current);
                current = "";
            }
            continue;
        }

        current += char;
    }

    if (current.length > 0) {
        result.push(current);
    }

    return result;
}
