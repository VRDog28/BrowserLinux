    if (e.ctrlKey && e.key.toLowerCase() === "q") {
        await exitNano();
        return;
    }

    if (e.key === "ArrowUp") {
        cursorY = Math.max(0, cursorY - 1);
        cursorX = Math.min(cursorX, buffer[cursorY].length);
        render();
        return;
    }
    if (e.key === "ArrowDown") {
        cursorY = Math.min(buffer.length - 1, cursorY + 1);
        cursorX = Math.min(cursorX, buffer[cursorY].length);
        render();
        return;
    }
    if (e.key === "ArrowLeft") {
        if (cursorX > 0) cursorX--;
        else if (cursorY > 0) {
