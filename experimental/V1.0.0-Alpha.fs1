/usr/bin/lolcat.js
36
if (!window.pipe || !window.pipe.length) {
  write("Usage: <text> | lolcat\n", "red");
  return;
}

const text = window.pipe;
const lines = text.split("\n");

// Gradient: bright green -> bright cyan
const startColor = { r: 0, g: 255, b: 0 };
const endColor   = { r: 0, g: 255, b: 255 };

function lerp(start, end, t) {
  return Math.round(start + (end - start) * t);
}

// For each line
for (let li = 0; li < lines.length; li++) {
  const line = lines[li];
  const lineLength = line.length;

  for (let i = 0; i < lineLength; i++) {
    // Raise t to 0.5 to accelerate interpolation
    let t = i / Math.max(lineLength - 1, 1);
    t = Math.pow(t, 0.5); // faster gradient

    const r = lerp(startColor.r, endColor.r, t);
    const g = lerp(startColor.g, endColor.g, t);
    const b = lerp(startColor.b, endColor.b, t);

    write(line[i], `rgb(${r},${g},${b})`);
  }

  write("\n");
}

