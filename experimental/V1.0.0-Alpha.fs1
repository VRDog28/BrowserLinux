if (!args || args.length === 0) {
  write("Usage: touch <filename>\n", "red");
} else {
  const filename = args[0];

  // --------------------
  // Determine full path
  // --------------------
  let path;
  if (filename.startsWith("/")) {
    path = filename.replace(/\/+/g, "/"); // absolute
  } else {
    path = (cwd === "/" ? "/" : cwd + "/") + filename; // relative
    path = path.replace(/\/+/g, "/");
  }

  // --------------------
  // Extract folder path
  // --------------------
  const parts = path.split("/");
  parts.pop(); // remove filename
  const folderPath = parts.join("/") || "/"; // root if empty

  // --------------------
  // Helper: get effective write permission recursively
  // --------------------
  function getEffectiveWritePermission(folderPath) {
    const parts = folderPath.split("/").filter(Boolean);
    let currentPath = "/";
    let permission = 0; // default

    for (const part of parts) {
      currentPath = currentPath === "/" ? "/" + part : currentPath + "/" + part;
      if (fs.meta[currentPath] && fs.meta[currentPath].writepermission !== undefined) {
        permission = parseInt(fs.meta[currentPath].writepermission);
      }
    }
    return permission;
  }

  // --------------------
  // Check folder exists
  // --------------------
  if (folderPath !== "/" && !fs.folders.includes(folderPath)) {
    write(`Error: Folder does not exist: ${folderPath}\n`, "red");
    return;
  }

  // --------------------
  // Check write permission
  // --------------------
  const folderWritePerm = getEffectiveWritePermission(folderPath);
  if (userPermission < folderWritePerm && userPermission !== 4) {
    write(`Access denied: cannot create file in ${folderPath}\n`, "red");
    return;
  }

  // --------------------
  // Create file
  // --------------------
  if (fs.files.hasOwnProperty(path)) {
    write(`File already exists: ${filename}\n`, "yellow");
  } else {
    fs.files[path] = "";
    write(`Created file: ${filename}\n`, "green");

    if (typeof saveFS1 === "function") await saveFS1();
  }
}
