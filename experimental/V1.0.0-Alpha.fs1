// --------------------
// kernel.js
// --------------------
const screen = document.getElementById("screen");
const startTime = Date.now();

// --------------------
// Output functions
// --------------------
function write(text, color, bg) {
  const defaultColor = "white";
  const defaultBg = "black";

  color = color || (window.theme ? window.theme[0] : defaultColor);
  bg = bg || (window.theme ? window.theme[1] : defaultBg);

  screen.style.overflowY = "auto";
  screen.style.maxHeight = screen.style.maxHeight || "100%"; // fallback if height not set

  for (let char of text) {
    const span = document.createElement("span");
    span.textContent = char;
    span.style.color = color;
    span.style.backgroundColor = bg;
    span.style.fontSize = window.theme?.[3] || "14px";
    screen.appendChild(span);
  }
}

function log(header, text, save=false) {
    const logPath = "/var/syslog.log";

    // Ensure \var folder exists
    if (!fs.folders.includes("/var")) {
        fs.folders.push("/var");
    }

    // Create log file if it doesn't exist
    if (!fs.files.hasOwnProperty(logPath)) {
        fs.files[logPath] = "";
    }

    // Split text into lines and prepend header to each line
    const lines = text.split("\n");
    const entry = lines.map(line => `${header}: ${line}`).join("\n") + "\n";

    // Append to log file
    fs.files[logPath] += entry;
    if (save) console.log("hi");
}

function clear() {
  screen.innerHTML = "";
}

function newline() {
  screen.appendChild(document.createElement("br"));
}

function wait(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

function formatTime(ms) {
  const totalSeconds = Math.floor(ms / 1000);
  const hours = String(Math.floor(totalSeconds / 3600)).padStart(2, '0');
  const minutes = String(Math.floor((totalSeconds % 3600) / 60)).padStart(2, '0');
  const seconds = String(totalSeconds % 60).padStart(2, '0');
  return `${hours}:${minutes}:${seconds}`;
}

// --------------------
// Filesystem & handle (from BIOS)
// --------------------
let fs = window.fs || { folders: [], files: {}, meta: {} };
let fs1FileHandle = window.fs1FileHandle || null;



// --------------------
// Parse FS1
// --------------------
function parseFS1(text) {
  const lines = text.split("\n").map(l => l.trim());
  let i = 0;
  const parsedFS = { folders: [], files: {}, meta: {} };

  while (i < lines.length) {
    const line = lines[i];
    if (line === "--folders") { i++; while(i<lines.length&&!lines[i].startsWith("--")) parsedFS.folders.push(lines[i++]); }
    else if (line === "--files") {
      i++; while(i<lines.length&&!lines[i].startsWith("--")){
        const path=lines[i++], count=parseInt(lines[i++]), content=[];
        for(let j=0;j<count;j++) content.push(lines[i++]);
        parsedFS.files[path] = content.join("\n");
      }
    } else if(line=="--meta"){
      i++; while(i<lines.length&&!lines[i].startsWith("--")){
        const path=lines[i++], count=parseInt(lines[i++]), meta={};
        for(let j=0;j<count;j++){ const [k,v]=lines[i++].split("="); meta[k.toLowerCase()]=v; }
        parsedFS.meta[path]=meta;
      }
    } else i++;
  }
  return parsedFS;
}

// --------------------
// Save FS1
// --------------------
async function saveFS1() {
  if (!fs1FileHandle) {
    write("No FS1 file selected to save.\n", "red");
    return;
  }

  const lines = ["fs1", "--folders", ...fs.folders, "--files"];
  for (const path in fs.files) {
    const content = fs.files[path].split("\n");
    lines.push(path);
    lines.push(content.length.toString());
    lines.push(...content);
  }

  lines.push("--meta");
  for (const path in fs.meta) {
    const meta = fs.meta[path];
    const keys = Object.keys(meta);
    lines.push(path);
    lines.push(keys.length.toString());
    for (const k of keys) lines.push(`${k}=${meta[k]}`);
  }
  lines.push("--end");

  try {
    const writable = await fs1FileHandle.createWritable();
    await writable.write(lines.join("\n"));
    await writable.close();
  } catch (e) {
    write("Failed to save: " + e.message + "\n", "red");
  }
}

// --------------------
// Run FS1 script
// --------------------
async function runFile(path) {
  const code = fs.files[path];
  if (!code) {
    log("kernel", "FILE NOT FOUND", true);
    write("File not found: " + path + "\n","red");
    return;
  }

  try {
    await new Function(`return (async ()=>{ ${code} })();`)();
  } catch(e) {
    log("kernel","Error: "+e.message,true);
    write("Error: "+e.message+"\n","red");
  }
}

// --------------------
// Apply font from FS1 file
// --------------------
async function applyFontFromFile() {
  if (!window.font) return;
  const path = window.font.replace(/\/+/g, "/");
  if (!fs.files.hasOwnProperty(path)) {
    log("kernel","CRITICAL ERROR",true);
    write("CRITICAL ERROR: Font file not found!\n","yellow","red");
    throw new Error("Font file not found!");
  }

  const fontContent = fs.files[path].trim();
  const styleEl = document.createElement("style");
  styleEl.innerHTML = `body, #screen { font-family: ${fontContent} !important; }`;
  document.head.appendChild(styleEl);
}

// --------------------
// Start FS1 auto-sync
// --------------------
function startFSSync() {
  setInterval(async()=>{
    if(!fs1FileHandle) return;
    try{
      const file = await fs1FileHandle.getFile();
      const fs1Content = await file.text();
      const newFS = parseFS1(fs1Content);

      fs.folders.length=0; fs.folders.push(...newFS.folders);
      for(const k in fs.files) delete fs.files[k]; for(const k in newFS.files) fs.files[k]=newFS.files[k];
      for(const k in fs.meta) delete fs.meta[k]; for(const k in newFS.meta) fs.meta[k]=newFS.meta[k];
    } catch(e) {
      log("kernel","FS1 SYNC FAILED",true);
      write("[FS1 sync failed: "+e.message+"]\n","red");
    }
  },5000);
}

// --------------------
// Kernel input for superuser password
// --------------------
async function requestSuperuserPassword(callback) {
  window.inputMode = "password";
  write("Superuser password: ","yellow");

  let buffer = "";
  const inputSpan = document.createElement("span");
  screen.appendChild(inputSpan);

  const handler = async e => {
    if(e.key==="Backspace"){ if(buffer.length>0){ buffer=buffer.slice(0,-1); inputSpan.lastChild?.remove(); } e.preventDefault(); return; }
    if(e.key==="Enter"){ newline(); document.removeEventListener("keydown",handler); await callback(buffer); window.inputMode="command"; return; }
    if(e.key.length===1){ buffer+=e.key; inputSpan.appendChild(document.createTextNode("*")); }
  };
  document.addEventListener("keydown",handler);
}

// --------------------
// Kernel boot
// --------------------
async function boot() {
  clear();
  write("Booting FS1 from BIOS...\n","gray");
  log("Boot","Starting boot process");

  // Use FS1 loaded by BIOS
  fs = window.fs;
  fs1FileHandle = window.fs1FileHandle;

  window.__blacklist = new Set();
  Object.keys(window).forEach(k=>window.__blacklist.add(k));

  // Remove temporary files
  for(const path in fs.files) if(path.startsWith("/tmp/") && path!="/tmp/") delete fs.files[path];


  // Run config if exists
  if(fs.files["/etc/config.js"]){ log("Boot","Running config.js"); await runFile("/etc/config.js"); }

  await applyFontFromFile();

  // Superuser password
  if(!fs.meta["/etc"]?.[".superuser"]){
    log("Boot","Requesting superuser password");
    if(!fs.meta["/etc"]) fs.meta["/etc"]={};
    await new Promise(res=>{ requestSuperuserPassword(async pw=>{ fs.meta["/etc"][".superuser"]=pw; write("\nSuperuser password set!\n","green"); await saveFS1(); res(); }); });
  }

  // Start FS1 sync
  // startFSSync();

  document.body.style.backgroundColor = window.theme?.[2] || "black";
  log("Boot","Running /boot/boot.js",true);
  await runFile("/boot/boot.js"); // start user terminal
}

// --------------------
// Expose functions globally
// --------------------
window.write = write;
window.clear = clear;
window.newline = newline;
window.fs = fs;
window.runFile = runFile;
window.wait = wait;
window.saveFS1 = saveFS1;
window.boot = boot;
window.log = log;
window.requestSuperuserPassword = requestSuperuserPassword;

// --------------------
// Show uptime
// --------------------
setInterval(()=>{
  const elapsed = Date.now() - startTime;
  window.uptime = formatTime(elapsed);
},1000);

boot();
