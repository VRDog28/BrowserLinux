if (!args || args.length === 0) {
  write("Usage: nano <file>\n", "red");
  return;
}

const filename = args[0];

// --------------------
// Resolve full path
// --------------------
let path;
if (filename.startsWith("/")) {
  path = filename.replace(/\/+/g, "/");
} else {
  path = (cwd === "/" ? "/" : cwd + "/") + filename;
  path = path.replace(/\/+/g, "/");
}

// --------------------
// Parent folder check
// --------------------
const parts = path.split("/");
parts.pop(); // remove filename
const parentFolder = parts.join("/") || "/";

if (parentFolder !== "/" && !fs.folders.includes(parentFolder)) {
  write(`Error: Parent folder does not exist: ${parentFolder}\n`, "red");
  return;
}

// --------------------
// Write permission
// --------------------
function getEffectiveWritePermission(folderPath) {
  const parts = folderPath.split("/").filter(Boolean);
  let currentPath = "/";
  let writePerm = 0;
  for (const part of parts) {
    currentPath = currentPath === "/" ? "/" + part : currentPath + "/" + part;
    if (fs.meta[currentPath]?.writepermission !== undefined) {
      writePerm = parseInt(fs.meta[currentPath].writepermission);
    }
  }
  return writePerm;
}

const parentWritePerm = getEffectiveWritePermission(parentFolder);
if (parentWritePerm > userPermission && userPermission !== 4) {
  write(`Access denied: cannot write to folder ${parentFolder}\n`, "red");
  return;
}

// --------------------
// Load file
// --------------------
let buffer = (fs.files[path] || "").split("\n");
if (buffer.length === 0) buffer = [""];

let cursorY = 0, cursorX = 0, isOpen = true;

window.inputMode = "nano";
screen.innerHTML = "";

// --------------------
// Render
// --------------------
function render() {
  clear();
  buffer.forEach((line, i) => {
    for (let j = 0; j <= line.length; j++) {
      if (i === cursorY && j === cursorX) {
        write(line[j] || " ", "black", "white"); // cursor
      } else if (j < line.length) {
        write(line[j], "white");
      }
    }
    newline();
  });
  write("-- NANO -- Ctrl+S=Save Ctrl+Q=Quit\n", "green");
}

// --------------------
// Exit nano
// --------------------
async function exitNano() {
  document.removeEventListener("keydown", nanoKeyHandler);
  window.inputMode = "command";

  // Save the file
  fs.files[path] = buffer.join("\n");
  if (typeof saveFS1 === "function") await saveFS1();

  // Clear Nano screen
  clear();

  prompt();

  isOpen = false;
}

// --------------------
// Key handler
// --------------------
async function nanoKeyHandler(e) {
  if (window.inputMode !== "nano") return;
  e.preventDefault();

  // Ctrl+S = save
  if (e.ctrlKey && e.key.toLowerCase() === "s") {
    fs.files[path] = buffer.join("\n");
    if (typeof saveFS1 === "function") await saveFS1();
    write(`\nSaved "${path}"\n`, "green");
    render();
    return;
  }

  // Ctrl+Q = quit
  if (e.ctrlKey && e.key.toLowerCase() === "q") {
    await exitNano();
    return;
  }

  // Arrows
  if (e.key === "ArrowUp") { cursorY = Math.max(0, cursorY - 1); cursorX = Math.min(cursorX, buffer[cursorY].length); render(); return; }
  if (e.key === "ArrowDown") { cursorY = Math.min(buffer.length - 1, cursorY + 1); cursorX = Math.min(cursorX, buffer[cursorY].length); render(); return; }
  if (e.key === "ArrowLeft") { if (cursorX > 0) cursorX--; else if (cursorY > 0) { cursorY--; cursorX = buffer[cursorY].length; } render(); return; }
  if (e.key === "ArrowRight") { if (cursorX < buffer[cursorY].length) cursorX++; else if (cursorY < buffer.length - 1) { cursorY++; cursorX = 0; } render(); return; }

  // Enter
  if (e.key === "Enter") {
    const line = buffer[cursorY];
    buffer[cursorY] = line.slice(0, cursorX);
    buffer.splice(cursorY + 1, 0, line.slice(cursorX));
    cursorY++; cursorX = 0;
    render();
    return;
  }

  // Backspace
  if (e.key === "Backspace") {
    const line = buffer[cursorY];
    if (cursorX > 0) {
      buffer[cursorY] = line.slice(0, cursorX - 1) + line.slice(cursorX);
      cursorX--;
    } else if (cursorY > 0) {
      cursorX = buffer[cursorY - 1].length;
      buffer[cursorY - 1] += buffer[cursorY];
      buffer.splice(cursorY, 1);
      cursorY--;
    }
    render();
    return;
  }

  // Normal characters
  if (e.key.length === 1) {
    const line = buffer[cursorY];
    buffer[cursorY] = line.slice(0, cursorX) + e.key + line.slice(cursorX);
    cursorX++;
    render();
  }
}

// --------------------
// Start
// --------------------
document.addEventListener("keydown", nanoKeyHandler);
render();
