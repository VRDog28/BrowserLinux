const filename = args[0];

if (!filename) {
  write("Usage: cat <filename>\n", "red");
  return;
}

// --------------------
// Resolve full path
// --------------------
let path;
if (filename.startsWith("/")) {
  path = filename.replace(/\/+/g, "/");
} else {
  path = (cwd === "/" ? "/" : cwd + "/") + filename;
  path = path.replace(/\/+/g, "/");
}

// --------------------
// Check if parent folder exists
// --------------------
function getParentFolder(path) {
  const parts = path.split("/");
  parts.pop(); // remove filename
  return parts.join("/") || "/";
}

const parentFolder = getParentFolder(path);
if (!fs.folders.includes(parentFolder) && parentFolder != "/") {
  write(`Folder does not exist: ${parentFolder}\n`, "red");
  return;
}

// --------------------
// Check read permission
// --------------------
function hasReadPermission(path) {
  if (userPermission === 4) return true; // superuser bypass

  const parts = path.split("/").filter(Boolean);
  let currentPath = "/";
  let readPerm = 0;

  for (const part of parts) {
    currentPath = currentPath === "/" ? "/" + part : currentPath + "/" + part;
    const meta = fs.meta[currentPath];
    if (!meta) continue;

    if (meta.readpermission !== undefined) readPerm = parseInt(meta.readpermission);
  }

  return userPermission >= readPerm;
}

if (!hasReadPermission(path)) {
  write(`Access denied: ${filename}\n`, "red");
  return;
}

// --------------------
// Display file content
// --------------------
if (fs.files.hasOwnProperty(path)) {
  log("cat", "cat successful")
  write(fs.files[path] + "\n", "white");
} else {
  write(`File not found: ${filename}\n`, "red");
}
