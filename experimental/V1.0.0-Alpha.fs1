let input = "";
let cursorPos = 0;
let inputLineEl = null;



function prompt() {
  input = "";
  cursorPos = 0;

  const line = document.createElement("div");
  screen.appendChild(line);
  inputLineEl = line;

  renderInputLine();
}

function setVar(name, value) {
  if (!name || typeof name !== "string") {
    write("Invalid variable name\n", "red");
    return;
  }
  log("Terminal", "Attempting to set variable");

  // --------------------
  // Permission check
  // --------------------
  if (window.protectedVars?.has(name) && userPermission !== 4) {
    write(`Permission denied: cannot modify '${name}' (requires sudo)\n`, "red");
    return;
  }
  if (name=="userPermission") {
    log("Terminal", "Dangerous user request catched");
  }

  const varConfPath = "/tmp/var.conf";

  if (!fs.files[varConfPath]) fs.files[varConfPath] = "";

  const lines = fs.files[varConfPath]
    .split("\n")
    .filter(l => l.trim() !== "");

  let found = false;

  for (let i = 0; i < lines.length; i++) {
    const eq = lines[i].indexOf("=");
    if (eq === -1) continue;
    const key = lines[i].slice(0, eq).trim();
    if (key === name) {
      lines[i] = `${name}=${JSON.stringify(value)}`;
      found = true;
      break;
    }
  }

  if (!found) {
    lines.push(`${name}=${JSON.stringify(value)}`);
  }

  fs.files[varConfPath] = lines.join("\n");

  // Update window
  window[name] = value;

  // Track allowed keys
  if (!window.allowedKeys) window.allowedKeys = new Set();
  window.allowedKeys.add(name);

  // Save immediately
  if (typeof saveFS1 === "function") saveFS1();

}

// Handle command execution
async function executeCommand(cmdLine) {
  let targetFile = null;
  let append = false; // overwrite or append flag
  let commandPart = cmdLine;


  const assignMatch = cmdLine.match(/^([a-zA-Z_]\w*)=(.+)$/);
  if (assignMatch) {
    const varName = assignMatch[1];
    let varValue;
    try {
      varValue = Function(`"use strict"; return (${assignMatch[2]});`)();
    } catch {
      varValue = assignMatch[2]; // fallback to string
    }
    setVar(varName, varValue);
    return; // stop further command execution
  }

  // --------------------
  // Detect redirection
  // --------------------
  if (cmdLine.includes(">>")) {
    const parts = cmdLine.split(">>");
    commandPart = parts[0].trim();
    targetFile = parts[1].trim();
    append = true;
  } else if (cmdLine.includes(">")) {
    const parts = cmdLine.split(">");
    commandPart = parts[0].trim();
    targetFile = parts[1].trim();
    append = false;
  }

  // --------------------
  // Detect pipe
  // --------------------
  const pipeParts = commandPart.split("|").map(p => p.trim());
  if (pipeParts.length > 1) {
    let capturedOutput = "";
    const originalWrite = write;
    write = (text, color = "white", bg = "black") => {
      capturedOutput += text;
    };

    await executeCommand(pipeParts[0]);
    write = originalWrite;

    capturedOutput = capturedOutput.replace(/\n$/, "");
    window.pipe = capturedOutput;

    await executeCommand(pipeParts.slice(1).join(" | "));
    window.pipe = "";
    return;
  }

  // --------------------
  // Replace $VAR using only keys present in \tmp\var.conf
  // --------------------
  if (fs.files["/tmp/var.conf"]) {
    const allowedKeys = new Set();

    fs.files["/tmp/var.conf"].split("\n").forEach(line => {
      const eq = line.indexOf("=");
      if (eq === -1) return;
      const key = line.slice(0, eq).trim();
      if (key) allowedKeys.add(key);
    });

    commandPart = commandPart.replace(/\$([a-zA-Z_]\w*)/g, (_, varName) => {
      if (allowedKeys.has(varName) && !window.__blacklist.has(varName) && window[varName] !== undefined) {
        const val = window[varName];
        return (typeof val === "object") ? JSON.stringify(val) : val;
      }
      return ""; // unknown or blacklisted variables expand to empty string
    });
  }

  // --------------------
  // Split command and args
  // --------------------
  const parts = commandPart.split(" ");
  const cmd = parts[0];
  const argsOrig = parts.slice(1);

  let originalWrite = write;
  let wroteToFile = false;

  // --------------------
  // Wrap write if redirection
  // --------------------
  if (targetFile) {
    write = (text, color = "white", bg = "black") => {
      let path;
      if (targetFile.startsWith("/")) {
        path = targetFile.replace(/\/+/g, "/");
      } else {

        path = (cwd === "/" ? "/" : cwd + "/") + targetFile;

        path = path.replace(/\/+/g, "/");
}

      const partsPath = path.split("/").filter(Boolean);
      let effectivePermission = 0;
      let currentPath = "/";
      for (const part of partsPath) {
        currentPath = currentPath === "/" ? "/" + part : currentPath + "/" + part;
        if (fs.meta[currentPath]?.permission !== undefined) {
          effectivePermission = parseInt(fs.meta[currentPath].permission);
        }
      }

      if (userPermission < effectivePermission && userPermission !== 4) {
        originalWrite(`Access denied to write: ${path}\n`, "red");
        return;
      }

      if (append) fs.files[path] = (fs.files[path] || "") + text;
      else fs.files[path] = text;
      wroteToFile = true;
    };
  }

  // --------------------
  // Find and execute command using window.path
  // --------------------
  let cmdPath = null;
  for (const base of window.path) {
    const fullPath = `${base}/${cmd}.js`;
    if (fs.files[fullPath]) {
      cmdPath = fullPath;
      break;
    }
  }

  if (cmdPath) {
    try {
      window.args = argsOrig;
      await runFile(cmdPath);
    } catch (e) {
      originalWrite(`Error executing ${cmd}: ${e.message}\n`, "red");
    }
  } else {
    originalWrite(`Command not found: ${cmd}\n`, "red");
  }

  if (targetFile) write = originalWrite;

  if (wroteToFile && typeof saveFS1 === "function") {
    await saveFS1();
  }
}
function renderInputLine() {
  if (!inputLineEl) {
    inputLineEl = document.createElement("div");
    screen.appendChild(inputLineEl);
  }

  inputLineEl.innerHTML = "";

  // Prompt ($ always lime)
  const promptSpan = document.createElement("span");
  promptSpan.textContent = "$ ";
  if (userPermission > 3) promptSpan.style.color = "red";
    if (userPermission < 4) promptSpan.style.color = "lime";
  promptSpan.style.backgroundColor = window.theme?.[1] || "black"; // theme background
  promptSpan.style.fontSize = window.theme?.[3] || "14px";
  promptSpan.style.fontFamily = getComputedStyle(document.body).fontFamily;
  inputLineEl.appendChild(promptSpan);

  // Input + cursor
  for (let i = 0; i <= input.length; i++) {
    const span = document.createElement("span");

    if (i === cursorPos) {
      span.textContent = input[i] || " ";
      span.style.backgroundColor = "white"; // cursor always white background
      span.style.color = "black";           // cursor text always black
    } else if (i < input.length) {
      span.textContent = input[i];
      span.style.color = window.theme?.[0] || "white";
      span.style.backgroundColor = window.theme?.[1] || "black";
    }

    span.style.fontSize = window.theme?.[3] || "14px";
    span.style.fontFamily = getComputedStyle(document.body).fontFamily;

    inputLineEl.appendChild(span);
  }
}

// Handle typing
document.addEventListener("keydown", async (e) => {
  if (window.inputMode !== "command") return;

  // Backspace
  if (e.key === "Backspace") {
    if (cursorPos > 0) {
      input = input.slice(0, cursorPos - 1) + input.slice(cursorPos);
      cursorPos--;
      renderInputLine();
    }
    e.preventDefault();
    return;
  }

  // Arrow LEFT
  if (e.key === "ArrowLeft") {
    cursorPos = Math.max(0, cursorPos - 1);
    renderInputLine();
    e.preventDefault();
    return;
  }

  // Arrow RIGHT
  if (e.key === "ArrowRight") {
    cursorPos = Math.min(input.length, cursorPos + 1);
    renderInputLine();
    e.preventDefault();
    return;
  }

  // Enter
  if (e.key === "Enter") {
    if (inputLineEl) {
      inputLineEl.innerHTML = "";

      // Prompt ($ always lime)
      const promptSpan = document.createElement("span");
      promptSpan.textContent = "$ ";
      if (userPermission > 3) promptSpan.style.color = "red";
      if (userPermission < 4) promptSpan.style.color = "lime";
      promptSpan.style.backgroundColor = window.theme?.[1] || "black";
      promptSpan.style.fontSize = window.theme?.[3] || "14px";
      promptSpan.style.fontFamily = getComputedStyle(document.body).fontFamily;
      inputLineEl.appendChild(promptSpan);

      // Input text
      const textSpan = document.createElement("span");
      textSpan.textContent = input;
      textSpan.style.color = window.theme?.[0] || "white";
      textSpan.style.backgroundColor = window.theme?.[1] || "black";
      textSpan.style.fontSize = window.theme?.[3] || "14px";
      textSpan.style.fontFamily = getComputedStyle(document.body).fontFamily;
      inputLineEl.appendChild(textSpan);
    }

    const newLine = document.createElement("div");
    screen.appendChild(newLine);

    if (input.trim() !== "") {
      await executeCommand(input);
    }

    inputLineEl = null;
    prompt();
    return;
  }

  // Normal characters
  if (e.key.length === 1) {
    input = input.slice(0, cursorPos) + e.key + input.slice(cursorPos);
    cursorPos++;
    renderInputLine();
  }
});

// --------------------
// Start terminal prompt
// --------------------

window.prompt = prompt;
window.executeCommand = executeCommand;
log("Terminal", "Starting main prompt", true);
prompt();
