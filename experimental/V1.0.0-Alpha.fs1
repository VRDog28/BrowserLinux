// --------------------
// Load etc\config.conf to get profile path
// --------------------
const etcConfigPath = "/etc/config.conf";

let profilePath = null;

if (!fs.files[etcConfigPath]) {
  write("No /etc/config.conf found, using defaults.\n");
  profilePath = "/etc/profiles/default.conf";
} else {
  const etcLines = fs.files[etcConfigPath].split("\n");

  for (let line of etcLines) {
    line = line.trim();
    if (!line || line.startsWith("#")) continue;

    const eq = line.indexOf("=");
    if (eq === -1) continue;

    const key = line.slice(0, eq).trim();
    const valueStr = line.slice(eq + 1).trim();

    if (key === "configfile") {
      try {
        profilePath = Function(`"use strict"; return (${valueStr});`)();
      } catch (e) {
        write("Failed to parse configfile path\n");
      }
      break;
    }
  }
}

if (!profilePath) {
  write("No configfile specified in /etc/config.conf\n");
} else if (!fs.files[profilePath]) {
  write(`Profile file not found: ${profilePath}\n`);
} else {
  // --------------------
  // Load actual profile dynamically
  // --------------------
  const lines = fs.files[profilePath].split("\n");
  window.protectedVars = new Set();

  for (let line of lines) {
    line = line.trim();
    if (!line || line.startsWith("#")) continue;

    const eq = line.indexOf("=");
    if (eq === -1) continue;

    const key = line.slice(0, eq).trim();
    window.protectedVars.add(key);
    const valueStr = line.slice(eq + 1).trim();

    try {
      const value = Function(`"use strict"; return (${valueStr});`)();
      window[key] = value;
    } catch (e) {
      write(`Failed to parse line in profile: ${line}\n`);
    }
  }

  // --------------------
  // Create per-session snapshot in \tmp\var.conf
  // --------------------
  if (!fs.folders.includes("/tmp")) fs.folders.push("/tmp");

  fs.files["/tmp/var.conf"] = fs.files[profilePath]; // exact same content as profile
  saveFS1();
}

// --------------------
// Config loaded
// --------------------
write("Config loaded\n");
