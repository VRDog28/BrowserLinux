// neofetch.js
// --------------------
// Display system info
// --------------------
const osName = window.osName;
const browserName = window.browserName;
const userName = window.userName;
const hostName = window.hostName;
const cwdDisplay = cwd || "\\";

const terminalWidth = 50; // width of the ASCII box

// --------------------
// Helper: pad string
// --------------------
function pad(str, length) {
  return str + " ".repeat(Math.max(0, length - str.length));
}

// --------------------
// ASCII logo (simple)
const logo = [
  "  _      ____  ____  ______",
  " | |    / __ \\/ __ \\/ ____/",
  " | |   / / / / / / / __/   ",
  " | |__/ /_/ / /_/ / /___   ",
  " |____/\\____/\\____/_____/  "
];

// --------------------
// Info lines
const infoLines = [
  `User: ${userName}@${hostName}`,
  `OS: ${osName}`,
  `Browser: ${browserName}`,
  `CWD: ${cwdDisplay}`,
  `Date: ${new Date().toLocaleString()}`
];

// --------------------
// Display
for (let i = 0; i < Math.max(logo.length, infoLines.length); i++) {
  let logoPart = logo[i] || "";
  let infoPart = infoLines[i] || "";
  write(pad(logoPart, terminalWidth) + " " + infoPart + "\n", "cyan");
}

newline();
