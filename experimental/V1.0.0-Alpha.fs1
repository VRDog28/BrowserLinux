// --------------------
// ls command
// --------------------
let target = args[0] || "."; // default is current folder
let listPath;

// --------------------
// Resolve path
// --------------------
if (target === ".") {
  listPath = cwd;
} else if (target.startsWith("/")) {
  listPath = target.replace(/\/+/g, "/");
} else {
  listPath = (cwd === "/" ? "/" : cwd + "/") + target;
  listPath = listPath.replace(/\/+/g, "/");
}

// Ensure folder exists
if (listPath !== "/" && !fs.folders.includes(listPath)) {
  write(`Directory does not exist: ${target}\n`, "red");
  return;
}

// --------------------
// Check read permission
// --------------------
function getEffectiveReadPermission(folderPath) {
  const parts = folderPath.split("/").filter(Boolean);
  let currentPath = "/";
  let perm = 0;

  for (const part of parts) {
    currentPath = currentPath === "/" ? "/" + part : currentPath + "/" + part;
    if (fs.meta[currentPath] && fs.meta[currentPath].readpermission !== undefined) {
      perm = parseInt(fs.meta[currentPath].readpermission);
    }
  }

  return perm;
}

if (!(userPermission >= getEffectiveReadPermission(listPath) || userPermission === 4)) {
  write(`Access denied: cannot read ${target}\n`, "red");
  return;
}

// --------------------
// Prepare listing
// --------------------
const listed = [];
const prefix = listPath === "/" ? "/" : listPath + "/";

// List folders
for (const folder of fs.folders) {
  if (folder.startsWith(prefix)) {
    const relative = folder.slice(prefix.length);
    if (relative && !relative.includes("/")) {
      listed.push({ name: relative, type: "folder" });
    }
  }
}

// List files
for (const filePath in fs.files) {
  if (filePath.startsWith(prefix)) {
    const relative = filePath.slice(prefix.length);
    if (relative && !relative.includes("/")) {
      listed.push({ name: relative, type: "file" });
    }
  }
}

// --------------------
// Print output
// --------------------
for (const item of listed) {
  if (item.type === "folder") write(item.name + " ", "cyan");
}
for (const item of listed) {
  if (item.type === "file") write(item.name + " ", "white");
}
newline();
