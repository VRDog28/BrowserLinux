const lines = logo.split("\n");
const maxLines = Math.max(lines.length, info.length);

function writeColoredLogo(line) {
    let buffer = "";
    let type = null;

    function flush() {
        if (!buffer) return;

        if (type === "land") {
            write(buffer, "lime");
        } else if (type === "water") {
            write(buffer, "dodgerblue");
        } else {
            write(buffer, "lime");
        }

        buffer = "";
    }

    for (const ch of line) {
        let newType;

        if (ch === "*") newType = "land";
        else if ("-:+=.".includes(ch)) newType = "water";
        else newType = "other";

        if (newType !== type) {
            flush();
            type = newType;
        }

        buffer += ch;
    }

    flush();
}

function writeInfoLine(parts) {
    for (const [text, color, bg="black"] of parts) {
        write(text, color, bg);
    }
}

for (let i = 0; i < maxLines; i++) {
    const left = lines[i] || "";
    const right = info[i] || [];

    writeColoredLogo(left);

    const pad = Math.max(0, 40 - left.length);
    write(" ".repeat(pad), "white");

    if (right.length > 0) {
        writeInfoLine(right);
    }

    write("\n");
}
