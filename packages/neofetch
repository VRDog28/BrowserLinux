function detectBrowser() {
    const ua = navigator.userAgentData;

    if (ua?.brands) {
        for (const b of ua.brands) {
            if (b.brand.includes("Chrome")) return "Chrome";
            if (b.brand.includes("Edge")) return "Edge";
            if (b.brand.includes("Firefox")) return "Firefox";
            if (b.brand.includes("Safari")) return "Safari";
        }
    }


    const uaString = navigator.userAgent;

    if (uaString.includes("Firefox")) return "Firefox";
    if (uaString.includes("Edg")) return "Edge";
    if (uaString.includes("Chrome")) return "Chrome";
    if (uaString.includes("Safari")) return "Safari";

    return "Unknown";
}
